msgstr "%d кредитов на изображения / месяц"

msgid "Your plan"
msgstr "Ваш план"

msgid "Switch Plan"
msgstr "Сменить план"

msgid "Subscribe"
msgstr "Подписаться"

msgid "Billing is handled securely by Stripe. AI Featured Image Generator does not store your payment details."
msgstr "Биллинг обрабатывается безопасно через Stripe. Генератор изображений ИИ не хранит данные платёжных карт."

msgid "No API key configured. <a href=\"%s\">Add your key or subscribe →</a>"
msgstr "API-ключ не настроен. <a href=\"%s\">Добавить ключ или подписаться →</a>"

msgid "Subscription inactive. <a href=\"%s\">Manage billing →</a>"
msgstr "Подписка неактивна. <a href=\"%s\">Управление биллингом →</a>"

msgid "Too many requests. Please wait a moment and try again."
msgstr "Слишком много запросов. Подождите немного и попробуйте снова."

msgid "Image service temporarily unavailable. Please try again shortly."
msgstr "Сервис изображений временно недоступен. Повторите попытку позже."

msgid "Plugin not yet configured. <a href=\"%s\">Go to Billing →</a>"
msgstr "Плагин ещё не настроен. <a href=\"%s\">Перейти в Биллинг →</a>"

msgid "Image generation is not available."
msgstr "Генерация изображений недоступна."

msgid "Stripe price ID for plan \"%s\" not configured in wp-config.php."
msgstr "ID цены Stripe для плана \"%s\" не настроен в wp-config.php."

msgid "Stripe secret key not configured. Add STRIPE_SECRET_KEY to wp-config.php."
msgstr "Секретный ключ Stripe не настроен. Добавьте STRIPE_SECRET_KEY в wp-config.php."

msgid "Stripe API error (HTTP %d)."
msgstr "Ошибка API Stripe (HTTP %d)."
