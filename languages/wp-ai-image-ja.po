msgstr "<a href=\"%s\" target=\"_blank\" rel=\"noopener noreferrer\">platform.openai.com/api-keys</a> で API キーを取得してください。"

msgid "1792 × 1024 — Landscape (recommended for blog posts)"
msgstr "1792 × 1024 — 横長（ブログ投稿に推奨）"

