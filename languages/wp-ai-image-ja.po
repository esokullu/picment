msgstr "この投稿を編集する権限がありません。"

msgid "Image generated successfully."
msgstr "画像が正常に生成されました。"

msgid "Invalid plan selected."
msgstr "無効なプランが選択されました。"

msgid "No Stripe customer found. Please subscribe first."
msgstr "Stripe 顧客が見つかりません。まずサブスクリプションに登録してください。"

msgid "API key cannot be empty."
msgstr "API キーは空にできません。"

msgid "Saved. Switched to BYOK mode."
msgstr "保存しました。BYOK モードに切り替えました。"

msgid "No subscription found to sync."
msgstr "同期するサブスクリプションが見つかりません。"

msgid "Subscription synced."
msgstr "サブスクリプションが同期されました。"

msgid "Subscription activated! Welcome aboard."
msgstr "サブスクリプションが有効化されました！ようこそ。"

msgid "Checkout cancelled — no charge was made."
msgstr "チェックアウトがキャンセルされました — 請求は発生していません。"

