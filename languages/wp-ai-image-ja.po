msgstr "%s プラン"

msgid "Paid Plan"
msgstr "有料プラン"

msgid "AI Featured Image Generator — Billing"
msgstr "AI アイキャッチ画像ジェネレーター — 請求"

msgid "Current Plan"
msgstr "現在のプラン"

msgid "Mode"
msgstr "モード"

msgid "Not configured"
msgstr "未設定"

msgid "Trial Credits"
msgstr "トライアルクレジット"

msgid "(used)"
msgstr "（使用済み）"

msgid "Credits"
msgstr "クレジット"

msgid "this month"
msgstr "今月"

msgid "Status"
msgstr "ステータス"

msgid "Renews"
msgstr "更新日"

msgid "Manage Subscription →"
msgstr "サブスクリプションを管理 →"

msgid "Sync Status"
msgstr "ステータスを同期"

msgid "Use Your Own API Key (Free)"
msgstr "独自の API キーを使用（無料）"

msgid "Enter your OpenAI API key. We never see it — it stays in your WordPress database. No monthly charge from us."
msgstr "OpenAI API キーを入力してください。私たちがキーを見ることはなく、WordPress データベースに保存されます。当社からの月額料金はかかりません。"

msgid "Save &amp; Switch to BYOK"
msgstr "保存して BYOK に切り替え"

msgid "Get a key at <a href=\"%s\" target=\"_blank\" rel=\"noopener noreferrer\">platform.openai.com/api-keys</a>."
msgstr "<a href=\"%s\" target=\"_blank\" rel=\"noopener noreferrer\">platform.openai.com/api-keys</a> でキーを取得してください。"

msgid "Active mode"
msgstr "アクティブモード"

msgid "Rate-limited to 10 images/min."
msgstr "10 画像/分に制限されています。"

msgid "Subscribe to a Managed Plan"
msgstr "マネージドプランに登録"

msgid "We provide the OpenAI key — no setup needed. Credits reset on your monthly renewal date. No carry-over."
msgstr "OpenAI キーは当社が提供します — 設定不要。クレジットは毎月の更新日にリセットされます。繰り越しはありません。"

msgid "Current"
msgstr "現在"

msgid "%d image credits / month"
msgstr "%d 画像クレジット / 月"

msgid "Your plan"
msgstr "現在のプラン"

msgid "Switch Plan"
msgstr "プランを変更"

msgid "Subscribe"
msgstr "登録する"

msgid "Billing is handled securely by Stripe. AI Featured Image Generator does not store your payment details."
msgstr "請求は Stripe によって安全に処理されます。AI アイキャッチ画像ジェネレーターは支払い情報を保存しません。"

msgid "No API key configured. <a href=\"%s\">Add your key or subscribe →</a>"
msgstr "API キーが設定されていません。<a href=\"%s\">キーを追加するかサブスクリプションに登録 →</a>"

msgid "Subscription inactive. <a href=\"%s\">Manage billing →</a>"
msgstr "サブスクリプションが非アクティブです。<a href=\"%s\">請求を管理 →</a>"

msgid "Too many requests. Please wait a moment and try again."
msgstr "リクエストが多すぎます。しばらく待ってから再試行してください。"

msgid "Image service temporarily unavailable. Please try again shortly."
msgstr "画像サービスが一時的に利用できません。しばらくしてから再試行してください。"

msgid "Plugin not yet configured. <a href=\"%s\">Go to Billing →</a>"
msgstr "プラグインがまだ設定されていません。<a href=\"%s\">請求に移動 →</a>"

msgid "Image generation is not available."
msgstr "画像生成は利用できません。"

msgid "Stripe price ID for plan \"%s\" not configured in wp-config.php."
msgstr "プラン \"%s\" の Stripe 価格 ID が wp-config.php に設定されていません。"

msgid "Stripe secret key not configured. Add STRIPE_SECRET_KEY to wp-config.php."
msgstr "Stripe シークレットキーが設定されていません。wp-config.php に STRIPE_SECRET_KEY を追加してください。"

msgid "Stripe API error (HTTP %d)."
msgstr "Stripe API エラー (HTTP %d)。"
